{
  "name": "cse110-sp26-group15",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CSE 110 Spring 2026 Group 15 project",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "shx mkdir -p dist && shx cp index.html dist/index.html",
    "dev:pages": "wrangler pages dev dist",
    "db:migrate:local": "wrangler d1 migrations apply cse110-sp26-group15 --local",
    "db:seed:local": "wrangler d1 execute cse110-sp26-group15 --local --file=./db/seed.sql",
    "db:reset:local": "wrangler d1 execute cse110-sp26-group15 --local --file=./db/reset.sql",
    "db:migrate:remote": "wrangler d1 migrations apply cse110-sp26-group15 --remote",
    "db:seed:remote": "wrangler d1 execute cse110-sp26-group15 --remote --file=./db/seed.sql",
    "db:reset:remote": "wrangler d1 execute cse110-sp26-group15 --remote --file=./db/reset.sql"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "shx": "^0.4.0",
    "wrangler": "^4.0.0"
  }
}
